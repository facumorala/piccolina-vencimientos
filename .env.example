# Entorno
FLASK_ENV=development

# Clave secreta para firmar las cookies de sesion (Flask).
# En produccion DEBE setearse con un random largo (32+ chars).
SECRET_KEY=cambiar-en-prod-por-string-random-largo

# Base de datos. Si no se setea, usa SQLite local (vencimientos.db).
# En produccion (Railway) viene como postgres://... y el codigo lo
# normaliza a postgresql://...
# DATABASE_URL=postgresql://usuario:password@host:5432/dbname

# Bot de Telegram (opcional - si no esta, el bot no arranca).
# TELEGRAM_BOT_TOKEN=
# Chat ID de Facu (donde se mandan los recordatorios y avisos de actividad).
# TELEGRAM_CHAT_ID_FACU=
# IDs autorizados para usar comandos del bot.
# TELEGRAM_AUTHORIZED_IDS=123456,789012

# Webhook (solo si querés modo webhook en Railway). Sin esto, modo polling.
# TELEGRAM_WEBHOOK_BASE_URL=

# Passwords iniciales para el seed (si no hay, se generan random y se imprimen).
# ADMIN_PASSWORD=
# CONTADORAS_PASSWORD=

# Forzar reset de contraseñas (solo se setea por un deploy y despues se borra).
# FORCE_PASSWORD_RESET=false

# Horarios del scheduler (en hora Argentina, UTC-3).
# Resumen semanal de los lunes.
RESUMEN_LUNES_HORA=10
# Aviso 3 dias antes de cada vencimiento (chequeo diario).
AVISO_3D_HORA=9
# Aviso del dia del vencimiento.
AVISO_DIA_HORA=9
# Hora a la que corre el generador de recurrentes (dia 1 de cada mes).
GENERADOR_HORA=0
